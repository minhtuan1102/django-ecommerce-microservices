# ============================================
# LLM API Configuration
# ============================================
# Choose ONE of the following:

# Option 1: Google Gemini API (Recommended - Free tier available)
GEMINI_API_KEY=your-gemini-api-key-here
LLM_TYPE=gemini
LLM_MODEL=gemini-1.5-flash

# Option 2: OpenAI API (Requires paid account)
# OPENAI_API_KEY=sk-your-openai-key-here
# LLM_TYPE=openai
# LLM_MODEL=gpt-3.5-turbo

# Option 3: Mock responses (No API key needed, for testing only)
# LLM_TYPE=mock

# ============================================
# Database Configuration
# ============================================
DB_ENGINE=django.db.backends.postgresql
DB_NAME=bookstore_postgres
DB_USER=bookstore_user
DB_PASSWORD=bookstore_pass
DB_HOST=postgres-db
DB_PORT=5432

# JWT Configuration
JWT_SECRET=bookstore-jwt-secret
JWT_ISSUER=bookstore-auth-service
JWT_AUDIENCE=bookstore-clients

# AI Services Configuration
BEHAVIOR_SERVICE_URL=http://behavior-analysis-service:8000
CHATBOT_SERVICE_URL=http://consulting-chatbot-service:8000

# ChromaDB Configuration
CHROMA_PERSIST_DIRECTORY=/app/vectorstore
CHROMA_COLLECTION_NAME=knowledge_base

# Model Configuration
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
TEMPERATURE=0.7
MAX_TOKENS=1000
